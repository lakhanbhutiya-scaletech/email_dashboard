# Firebase Auth — same project ai-labs-frontend uses to get a verifiable
# Microsoft ID token (AI Labs' /auth/oauth-login verifies it server-side).
# Until these are set, the "Sign in with Microsoft" button shows the
# "not configured yet" note and falls back to the dev sign-in list below it.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Microsoft OAuth client id registered on Firebase's Microsoft provider
VITE_MICROSOFT_CLIENT_ID=
