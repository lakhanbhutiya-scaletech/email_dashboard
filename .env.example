# ── Customer backend settings ──────────────────────────────────────────────
PROJECT_NAME=Sales Outlook Dashboard
ENVIRONMENT=development

# Database (this backend owns its own Postgres — separate from AI Labs)
DATABASE_URL=postgresql+psycopg://ed_user:ed_password@localhost:5433/email_dashboard

# Encryption at rest for AI Labs API keys (Fernet). Generate a real one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=CHANGE_ME_generate_a_real_fernet_key

# ── AI Labs (source of truth for identity + Outlook token) ──────────────────
# Dev: local AI Labs on :8000.  Prod: https://ailabs.scaletechsolutions.ai
AILABS_BASE_URL=http://localhost:8000/api/v1
AILABS_TIMEOUT_SECONDS=120

# Defaults for provisioned employee agents (see spec §2/§6)
AGENT_MODEL=gpt-4o
AGENT_TEMPERATURE=0.2
AGENT_MAX_TOKENS=4096
AGENT_MEMORY_WINDOW=4

# ── Hourly cron ─────────────────────────────────────────────────────────────
CRON_ENABLED=true
CRON_INTERVAL_MINUTES=60
# Seconds to stagger between employees so we don't fire everyone at once (spec §4)
CRON_STAGGER_SECONDS=5
ANALYSIS_TIMEZONE=Asia/Kolkata

# Frontend origins allowed to call this backend (never use "*" with credentials)
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
